CASPER_NETWORK=casper-testnet
CASPER_NODE_ADDRESS=https://node.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test
CASPER_ACCOUNT_SECRET_KEY_PATH=/absolute/path/to/secret_key.pem
# Railway/container deploys can set this instead of mounting a raw PEM file.
# The entrypoint writes it to /app/secrets/casper-secret-key.pem.
CASPER_SECRET_KEY_PEM_BASE64=

# Odra livenet env aliases. Keep these in sync with the Casper values above.
ODRA_CASPER_LIVENET_RPC_ADDRESS=https://node.testnet.casper.network/rpc
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.casper.network/rpc
ODRA_CASPER_LIVENET_EVENTS_URL=https://node.testnet.casper.network/events
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=/absolute/path/to/secret_key.pem

UNDERWRITE_AGENT_ACCOUNT=
UNDERWRITE_ORACLE_PUBLIC_KEY=fd1724385aa0c75b64fb78cd602fa1d991fdebf76b13c58ed702eac835e9f618
DEMO_CLAIMANT_ACCOUNT=
# Optional: for scripts/register-policy-self.sh. Must match the livenet signer/caller.
UNDERWRITE_SELF_CLAIMANT_ACCOUNT=

UNDERWRITE_TOKEN_ADDRESS=
UNDERWRITE_CONTRACT_ADDRESS=
UNDERWRITE_VAULT_ADDRESS=
UNDERWRITE_POLICY_ID=MRC-CRG-2026-00481
UNDERWRITE_INSURED_VALUE_MINOR=12500000
UNDERWRITE_POLICY_CURRENCY=USD
UNDERWRITE_ATTESTATION_PATH=deployments/latest-attestation.json
UNDERWRITE_STALE_ATTESTATION_PATH=deployments/latest-stale-attestation.json
CASPER_DEPLOY_GAS=812500000000
CASPER_GAS_PRICE_TOLERANCE=1

DEPLOYMENT_OUTPUT=deployments/casper-testnet.json
CASPER_EXPLORER_BASE_URL=https://testnet.cspr.live

# Enables the Next.js operator console to send real Casper Testnet
# transactions from the server. Keep false/empty unless the server is
# intentionally configured with a funded Testnet key.
UNDERWRITE_ENABLE_OPERATOR_ACTIONS=false

# Public variables for Wallet Mode (Browser)
NEXT_PUBLIC_CASPER_CHAIN_NAME=casper-test
NEXT_PUBLIC_CASPER_RPC_URL=https://node.testnet.casper.network/rpc
NEXT_PUBLIC_CASPER_EXPLORER_BASE_URL=https://testnet.cspr.live
NEXT_PUBLIC_UNDERWRITE_CONTRACT_HASH=hash-cc9065bf2ddf323697c42fccb015fdd170832557ddc455fb9f3217820b09a36f

UNDERWRITE_ENABLE_AGENT_REQUESTS=true
